generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  code      Int
  questions Question[]
}

model Question {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  sessionId      String
  isOpen         Boolean  @default(true)
  content        String
  fromLine       Int
  toLine         Int
  language       String?
  answers        Answer[] @relation("answers")
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chosenAnswer   Answer?  @relation(fields: [chosenAnswerId], references: [id])
  chosenAnswerId String?
}

model Answer {
  id         String     @id @default(cuid())
  createdAt  DateTime   @default(now())
  text       String?
  questionId String
  question   Question   @relation("answers", fields: [questionId], references: [id], onDelete: Cascade)
  questions  Question[]
}
