{
  "name": "cocode",
  "displayName": "CoCode",
  "description": "An extension to present code with user participation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cocode",
          "title": "CoCode",
          "icon": "resources/icon-cocode.svg"
        }
      ]
    },
    "views": {
      "cocode": [
        {
          "id": "cocodeSidepanelView",
          "name": "Collaborative Coding",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "cocode.startSession",
        "title": "CoCode: Start New Session"
      },
      {
        "command": "cocode.rejoinSession",
        "title": "CoCode: Rejoin Previous Session"
      },
      {
        "command": "cocode.postQuestion",
        "title": "CoCode: Post Question"
      },
      {
        "command": "cocode.acceptSuggestion",
        "title": "CoCode: Accept Suggestion"
      },
      {
        "command": "cocode.rejectSuggestions",
        "title": "CoCode: Reject Suggestions"
      },
      {
        "command": "cocode.deleteSuggestion",
        "title": "CoCode: Delete Suggestions"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cocode.postQuestion",
          "group": "CoCode",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "CoCode",
      "type": "object",
      "properties": {
        "cocode.serverUrl": {
          "type": "string",
          "default": "https://cocode.kasperskov.dev",
          "description": "Location of CoCode server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "dotenv": "^17.3.1",
    "eventsource": "^4.1.0",
    "highlight.js": "^11.11.1",
    "vscode-position-tracking": "^0.1.0"
  }
}
