{
  "name": "cocode",
  "displayName": "CoCode",
  "description": "An extension to present code with user participation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsWelcome": [
      {
        "view": "cocodeCreateSession",
        "contents": "[Start Session](command:cocode.startSession)"
      },
      {
        "view": "cocodeCreateSession",
        "contents": "\n[Rejoin Previous Session](command:cocode.rejoinSession)",
        "when": "cocode.showRejoin&&!cocode.inSession"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cocode",
          "title": "CoCode",
          "icon": "resources/icon-cocode.svg"
        }
      ]
    },
    "views": {
      "cocode": [
        {
          "id": "cocodeCreateSession",
          "name": "Create Session",
          "type": "tree",
          "when": "!cocode.inSession"
        },
        {
          "id": "cocodeAnswers",
          "name": "Answers",
          "type": "webview",
          "when": "cocode.inSession"
        }
      ]
    },
    "commands": [
      {
        "command": "cocode.startSession",
        "title": "Start New Session"
      },
      {
        "command": "cocode.rejoinSession",
        "title": "Rejoin Previous Session"
      },
      {
        "command": "cocode.postQuestion",
        "title": "Post Question"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cocode.postQuestion",
          "group": "CoCode",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "vscode-position-tracking": "^0.1.0"
  }
}
